# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-from-botfather
# Comma-separated Telegram user IDs allowed to use the bot (get yours from @userinfobot)
ALLOWED_USER_IDS=12345678

# LLM provider: "gemini" (default) or "anthropic"
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3.1-flash-lite
# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Daily calorie goal (change anytime with /goal) and WHO-based limits
DEFAULT_CALORIE_GOAL=1800
# When to send the nightly summary push (24h clock, Asia/Singapore)
DAILY_SUMMARY_TIME=21:00
DAILY_SODIUM_LIMIT_MG=2000
DAILY_SUGAR_LIMIT_G=50
DAILY_CAFFEINE_LIMIT_MG=400

# Storage — SQLite is the source of truth
NUTRISNAP_DB=nutrisnap.db
# Optional Google Sheets mirror: activates automatically once this key file
# exists (see README). Leave as-is until then.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# Preferred: target the sheet by its ID (the long token in its URL).
# Falls back to opening by GSHEET_NAME if unset.
GSHEET_ID=
GSHEET_NAME=Nutrition Log
